\newlabel{fig:reliability}{{2}{10}{Calibration taxonomy scatter: ECE on ITB-HQ ($x$-axis) vs.\ ITB-LQ ($y$-axis). Methods above the diagonal are quality-oblivious; D+QCTS and Q-VIB Full approach the diagonal}{figure.2}{}}
\@writefile{lot}{\contentsline {table}{\numberline {2}{\ignorespaces ECE on ITB-LQ stratified by dominant degradation type (bottom 20th percentile of each dimension). Color temperature ($q_4$) is the most calibration-damaging degradation. D+QCTS consistently achieves lowest ECE across all types.}}{10}{table.2}\protected@file@percent }
\newlabel{tab:degradation}{{2}{10}{ECE on ITB-LQ stratified by dominant degradation type (bottom 20th percentile of each dimension). Color temperature ($q_4$) is the most calibration-damaging degradation. D+QCTS consistently achieves lowest ECE across all types}{table.2}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {5.6}Cross-Dataset Generalization}{10}{subsection.5.6}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces Reliability diagrams conditioned on quality stratum (ITB-LQ vs.\ ITB-HQ). For quality-oblivious methods (MC Dropout, Deep Ensemble), the curves diverge sharply across strata; for quality-aware methods (Std VIB, Q-VIB Full), they nearly overlap.}}{11}{figure.3}\protected@file@percent }
\newlabel{fig:reliability_diag}{{3}{11}{Reliability diagrams conditioned on quality stratum (ITB-LQ vs.\ ITB-HQ). For quality-oblivious methods (MC Dropout, Deep Ensemble), the curves diverge sharply across strata; for quality-aware methods (Std VIB, Q-VIB Full), they nearly overlap}{figure.3}{}}
