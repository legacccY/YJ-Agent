\@writefile{lot}{\contentsline {table}{\numberline {1}{\ignorespaces Main results across ITB subsets. Lower ECE and QCDI are better; QCDI $= \text  {ECE}_{\text  {LQ}} - \text  {ECE}_{\text  {HQ}}$. $\rho $: Spearman correlation between predictive entropy and $\bar  {q}$ on HAM10000 zero-shot (more negative $=$ more quality-aware; $\dagger $ ITB-measured, subject to stratification bias). \textbf  {Bold}: best Quality-Aware method per column.}}{8}{table.1}\protected@file@percent }
