\@writefile{toc}{\contentsline {section}{\numberline {A4}Decision-Curve Analysis and Triage Simulation}{4}{section.4}\protected@file@percent }
\newlabel{app:dca}{{A4}{4}{Decision-Curve Analysis and Triage Simulation}{section.4}{}}
\@writefile{lot}{\contentsline {table}{\numberline {S2}{\ignorespaces  \textbf  {QCTS under different quality scalars $\bar  q$.} QCTS is fitted with each quality estimator on the same frozen Std VIB backbone and val split. Fitted slope $\hat  \alpha $ indicates whether the quality scalar drives quality-aware temperature scaling. BRISQUE and CLIP-IQA collapse to quality-agnostic solutions ($\hat  \alpha \!\approx \!0$, equivalent to TS); Laplacian variance learns $\hat  \alpha \!>\!0$ but selects the wrong quality dimension (QCDI$\,{=}{+}0.028$, worse than TS); only the dermoscopy-trained 5-head IQA achieves quality-fair calibration (QCDI$\,{<}\,0$, most negative $\rho $). }}{5}{table.caption.7}\protected@file@percent }
\newlabel{tab:quality_scalar}{{S2}{5}{\textbf {QCTS under different quality scalars $\bar q$.} QCTS is fitted with each quality estimator on the same frozen Std VIB backbone and val split. Fitted slope $\hat \alpha $ indicates whether the quality scalar drives quality-aware temperature scaling. BRISQUE and CLIP-IQA collapse to quality-agnostic solutions ($\hat \alpha \!\approx \!0$, equivalent to TS); Laplacian variance learns $\hat \alpha \!>\!0$ but selects the wrong quality dimension (QCDI$\,{=}{+}0.028$, worse than TS); only the dermoscopy-trained 5-head IQA achieves quality-fair calibration (QCDI$\,{<}\,0$, most negative $\rho $)}{table.caption.7}{}}
\@writefile{lot}{\contentsline {table}{\numberline {S3}{\ignorespaces Maximum net benefit on ITB-LQ ($n{=}300$) with bootstrap $95\%$ CI ($n_\text  {boot}{=}2{,}000$).}}{5}{table.caption.8}\protected@file@percent }
\newlabel{tab:dca}{{S3}{5}{Maximum net benefit on ITB-LQ ($n{=}300$) with bootstrap $95\%$ CI ($n_\text {boot}{=}2{,}000$)}{table.caption.8}{}}
\@writefile{lot}{\contentsline {table}{\numberline {S4}{\ignorespaces Triage simulation at $20\%$ referral budget on ITB-LQ. \textbf  {Caveat:} the Std~VIB rows use a quality-fragile probe backbone with intentionally bottlenecked AUC ($0.553$ on ITB-LQ); QCTS calibrates probabilities but does not relocate the decision boundary, so the auto-AI sensitivity inherits the backbone's discriminative ceiling. The triage simulation therefore reflects backbone quality, not calibration quality.}}{5}{table.caption.10}\protected@file@percent }
\newlabel{tab:triage}{{S4}{5}{Triage simulation at $20\%$ referral budget on ITB-LQ. \textbf {Caveat:} the Std~VIB rows use a quality-fragile probe backbone with intentionally bottlenecked AUC ($0.553$ on ITB-LQ); QCTS calibrates probabilities but does not relocate the decision boundary, so the auto-AI sensitivity inherits the backbone's discriminative ceiling. The triage simulation therefore reflects backbone quality, not calibration quality}{table.caption.10}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {S6}{\ignorespaces \textbf  {Decision-curve analysis (left) and triage simulation (right) on ITB-LQ.} \emph  {Left}: net benefit vs.\ threshold; QCTS dominates Std VIB above threshold~$0.35$. \emph  {Right}: at a 20\% referral budget, QCTS reduces the missed-positive rate from 73.3\% to 70.0\%.}}{6}{figure.caption.9}\protected@file@percent }
\newlabel{fig:dca}{{S6}{6}{\textbf {Decision-curve analysis (left) and triage simulation (right) on ITB-LQ.} \emph {Left}: net benefit vs.\ threshold; QCTS dominates Std VIB above threshold~$0.35$. \emph {Right}: at a 20\% referral budget, QCTS reduces the missed-positive rate from 73.3\% to 70.0\%}{figure.caption.9}{}}
\@writefile{toc}{\contentsline {section}{\numberline {A5}MC Dropout and Deep Ensemble Quality-Awareness}{6}{section.5}\protected@file@percent }
\newlabel{app:uncertainty}{{A5}{6}{MC Dropout and Deep Ensemble Quality-Awareness}{section.5}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {S7}{\ignorespaces \textbf  {Entropy vs.\ $\bar  {q}$ scatter on ITB-LQ ($n{=}300$) for four methods.} MC Dropout achieves $\rho {=}+0.350$ ($p{<}10^{-9}$) and Deep Ensemble $\rho {=}+0.133$ ($p{=}0.021$), both positive: within the LQ stratum, these methods are \emph  {more} uncertain on marginally better-quality images --- quality-oblivious at the individual-prediction level. Std VIB + QCTS achieves $\rho {=}{-}0.112$ (one-sided $p{=}0.054$), consistently more negative than any other method in the LQ stratum.}}{6}{figure.caption.11}\protected@file@percent }
\newlabel{fig:uncertainty_qbar}{{S7}{6}{\textbf {Entropy vs.\ $\qbar $ scatter on ITB-LQ ($n{=}300$) for four methods.} MC Dropout achieves $\rho {=}+0.350$ ($p{<}10^{-9}$) and Deep Ensemble $\rho {=}+0.133$ ($p{=}0.021$), both positive: within the LQ stratum, these methods are \emph {more} uncertain on marginally better-quality images --- quality-oblivious at the individual-prediction level. Std VIB + QCTS achieves $\rho {=}{-}0.112$ (one-sided $p{=}0.054$), consistently more negative than any other method in the LQ stratum}{figure.caption.11}{}}
