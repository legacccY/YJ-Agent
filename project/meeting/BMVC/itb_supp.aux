\@writefile{toc}{\contentsline {section}{\numberline {A4}MC Dropout and Deep Ensemble Quality-Awareness}{3}{section.4}\protected@file@percent }
\newlabel{app:uncertainty}{{A4}{3}{MC Dropout and Deep Ensemble Quality-Awareness}{section.4}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {S2}{\ignorespaces \textbf  {Entropy vs.\ $\bar  {q}$ scatter on ITB-LQ ($n{=}300$) for four methods.} MC Dropout achieves $\rho {=}+0.350$ ($p{<}10^{-9}$) and Deep Ensemble $\rho {=}+0.133$ ($p{=}0.021$), both positive: within the LQ stratum, these methods are \emph  {more} uncertain on marginally better-quality images --- quality-oblivious at the individual-prediction level. Std VIB + QCTS achieves $\rho {=}{-}0.112$ (one-sided $p{=}0.054$), consistently more negative than any other method in the LQ stratum.}}{3}{figure.caption.6}\protected@file@percent }
\newlabel{fig:uncertainty_qbar}{{S2}{3}{\textbf {Entropy vs.\ $\qbar $ scatter on ITB-LQ ($n{=}300$) for four methods.} MC Dropout achieves $\rho {=}+0.350$ ($p{<}10^{-9}$) and Deep Ensemble $\rho {=}+0.133$ ($p{=}0.021$), both positive: within the LQ stratum, these methods are \emph {more} uncertain on marginally better-quality images --- quality-oblivious at the individual-prediction level. Std VIB + QCTS achieves $\rho {=}{-}0.112$ (one-sided $p{=}0.054$), consistently more negative than any other method in the LQ stratum}{figure.caption.6}{}}
