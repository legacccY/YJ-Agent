\@writefile{lot}{\contentsline {table}{\numberline {4}{\ignorespaces \textbf  {External transfer of QCTS.} Cross-dataset, fairness, cross-scalar (ImageNet-C corruption severity in place of $\bar  q$) and cross-modality probes. $\rho (H,\bar  q)$ reported on the indicated pool; ImageNet-C rows are the mean over 18 corruptions on the 300 ITB-LQ images. TS resurfaces the reversal on both unseen dermoscopy/photograph pools; QCTS preserves the directional gain or, where the backbone is already quality-aware, reduces gracefully to TS. Per-corruption and per-skin breakdowns in supp \S  A5/A6/A15.}}{9}{table.caption.5}\protected@file@percent }
\newlabel{tab:transfer}{{4}{9}{\textbf {External transfer of QCTS.} Cross-dataset, fairness, cross-scalar (ImageNet-C corruption severity in place of $\bar q$) and cross-modality probes. $\rho (H,\bar q)$ reported on the indicated pool; ImageNet-C rows are the mean over 18 corruptions on the 300 ITB-LQ images. TS resurfaces the reversal on both unseen dermoscopy/photograph pools; QCTS preserves the directional gain or, where the backbone is already quality-aware, reduces gracefully to TS. Per-corruption and per-skin breakdowns in supp \S A5/A6/A15}{table.caption.5}{}}
