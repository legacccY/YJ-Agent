\@writefile{lof}{\contentsline {figure}{\numberline {7}{\ignorespaces \textbf  {QCTS generalises across datasets, backbones, and skin tones.} \textbf  {(a)} Entropy vs.\ $\bar  q$ on HAM10000 zero-shot; the per-bin median trend (coloured line) becomes more negative from Std VIB to Std VIB + QCTS, confirming that the quality-aware behaviour learned on ISIC transfers to a natural-distribution dataset. \textbf  {(b)} QCDI on three datasets across the evaluated baselines, with Kendall~$\tau $ summarising ranking consistency. \textbf  {(c)} Per-skin-type QCDI on ITB-Diverse for Std VIB and Std VIB + QCTS; QCTS keeps the V--VI QCDI in the 0.01--0.02 range without introducing new bias on lighter skin types. \emph  {Takeaway:} the QCDI ranking from ITB transfers to two unseen dermoscopy datasets and narrows the Fitzpatrick V--VI calibration gap without harming lighter skin tones.}}{14}{figure.caption.10}\protected@file@percent }
\newlabel{fig:generalization}{{7}{14}{\textbf {QCTS generalises across datasets, backbones, and skin tones.} \textbf {(a)} Entropy vs.\ $\bar q$ on HAM10000 zero-shot; the per-bin median trend (coloured line) becomes more negative from Std VIB to Std VIB + QCTS, confirming that the quality-aware behaviour learned on ISIC transfers to a natural-distribution dataset. \textbf {(b)} QCDI on three datasets across the evaluated baselines, with Kendall~$\tau $ summarising ranking consistency. \textbf {(c)} Per-skin-type QCDI on ITB-Diverse for Std VIB and Std VIB + QCTS; QCTS keeps the V--VI QCDI in the 0.01--0.02 range without introducing new bias on lighter skin types. \emph {Takeaway:} the QCDI ranking from ITB transfers to two unseen dermoscopy datasets and narrows the Fitzpatrick V--VI calibration gap without harming lighter skin tones}{figure.caption.10}{}}
