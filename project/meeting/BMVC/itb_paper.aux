\@writefile{lot}{\contentsline {table}{\numberline {1}{\ignorespaces \textbf  {Main results on the ITB benchmark.} AUC and ECE ($M{=}15$ bins) on ITB-LQ ($n{=}300$) and ITB-HQ ($n{=}360$); $\text  {QCDI}=\mathrm  {ECE}_\mathrm  {LQ}-\mathrm  {ECE}_\mathrm  {HQ}$ (closer to $0$ is better); $\rho (H,\bar  q)$ is Spearman correlation on the full ITB pool ($n{=}2{,}820$, more negative is better). Values shown as $\text  {point}\,{\scriptscriptstyle \pm }\,\text  {half-width of $1{,}000$-iter bootstrap $95\%$ CI}$. \textbf  {Bold}/\underline  {underline}: directionally best/second per column (lower for ECE/QCDI, higher for AUC, more negative for $\rho $). The \textbf  {Std VIB + QCTS} row (highlighted) is our contribution; VIB-family models trade AUC for tighter calibration, so the headline metrics are ECE and QCDI.}}{9}{table.caption.3}\protected@file@percent }
\newlabel{tab:main}{{1}{9}{\textbf {Main results on the ITB benchmark.} AUC and ECE ($M{=}15$ bins) on ITB-LQ ($n{=}300$) and ITB-HQ ($n{=}360$); $\text {QCDI}=\mathrm {ECE}_\mathrm {LQ}-\mathrm {ECE}_\mathrm {HQ}$ (closer to $0$ is better); $\rho (H,\bar q)$ is Spearman correlation on the full ITB pool ($n{=}2{,}820$, more negative is better). Values shown as $\text {point}\,{\scriptscriptstyle \pm }\,\text {half-width of $1{,}000$-iter bootstrap $95\%$ CI}$. \textbf {Bold}/\underline {underline}: directionally best/second per column (lower for ECE/QCDI, higher for AUC, more negative for $\rho $). The \textbf {Std VIB + QCTS} row (highlighted) is our contribution; VIB-family models trade AUC for tighter calibration, so the headline metrics are ECE and QCDI}{table.caption.3}{}}
