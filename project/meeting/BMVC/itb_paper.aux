\@writefile{lot}{\contentsline {table}{\numberline {2}{\ignorespaces \textbf  {Where QCTS reduces ECE: per-degradation (ITB-LQ) and per-quality-bin (full ITB) breakdown.} The temperature lift concentrates on blur and colour-shift extremes (Panel a, top two rows) and on the lowest-quality 20\% of the pool (Panel b, top row), with diminishing returns on cleaner inputs. Negative reduction on low-contrast probes (Panel a, last row) is informative: contrast inflation \emph  {spreads} logits, so a quality-conditioned soften\-ing reduces the wrong dimension --- the failure mode QCTS does \emph  {not} repair. All values from $n_{\text  {ITB-LQ}}{=}300$ stratified probes ($n{=}60{-}71$ per dimension) and equi-population $\bar  {q}$ quintiles on full ITB ($n{=}564$ each).}}{10}{table.caption.4}\protected@file@percent }
\newlabel{tab:perdeg}{{2}{10}{\textbf {Where QCTS reduces ECE: per-degradation (ITB-LQ) and per-quality-bin (full ITB) breakdown.} The temperature lift concentrates on blur and colour-shift extremes (Panel a, top two rows) and on the lowest-quality 20\% of the pool (Panel b, top row), with diminishing returns on cleaner inputs. Negative reduction on low-contrast probes (Panel a, last row) is informative: contrast inflation \emph {spreads} logits, so a quality-conditioned soften\-ing reduces the wrong dimension --- the failure mode QCTS does \emph {not} repair. All values from $n_{\text {ITB-LQ}}{=}300$ stratified probes ($n{=}60{-}71$ per dimension) and equi-population $\qbar $ quintiles on full ITB ($n{=}564$ each)}{table.caption.4}{}}
\@writefile{lot}{\contentsline {table}{\numberline {3}{\ignorespaces \textbf  {Ablation on the form of $T(\bar  q)$.} Candidate functions fitted on a frozen Std VIB with identical L-BFGS optimisation and validation split (single-seed point estimates). Piecewise-constant minimises validation NLL but collapses QCDI and $\rho $, showing smooth interpolation is essential for quality-aware calibration; dimension-wise and MLP variants add parameters without measurable gain.}}{10}{table.caption.5}\protected@file@percent }
\newlabel{tab:ablation}{{3}{10}{\textbf {Ablation on the form of $T(\bar q)$.} Candidate functions fitted on a frozen Std VIB with identical L-BFGS optimisation and validation split (single-seed point estimates). Piecewise-constant minimises validation NLL but collapses QCDI and $\rho $, showing smooth interpolation is essential for quality-aware calibration; dimension-wise and MLP variants add parameters without measurable gain}{table.caption.5}{}}
