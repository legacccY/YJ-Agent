\bibcite{alemi2017vib}{{1}{2017}{{Alemi et~al.}}{{Alemi, Fischer, Dillon, and Murphy}}}
\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces \textbf  {Qualitative degradation gallery on four ground-truth benign lesions.} \emph  {Row~1} \textbf  {High Quality}: clean dermoscopy inputs. \emph  {Row~2} \textbf  {Blur} ($q_3$ axis), \emph  {Row~3} \textbf  {Colour} ($q_4$ hue axis), \emph  {Row~4} \textbf  {Combined}: blur + hue + contrast applied jointly. \emph  {Takeaway:} the programmatic degradations used to build ITB-LQ preserve lesion identity while sweeping the 5-head IQA scores into the low-quality stratum where Std~VIB calibration collapses and QCTS recovers it (Tables~\ref {tab:main}--\ref {tab:universality}).}}{10}{figure.caption.6}\protected@file@percent }
\newlabel{fig:teaser}{{2}{10}{\textbf {Qualitative degradation gallery on four ground-truth benign lesions.} \emph {Row~1} \textbf {High Quality}: clean dermoscopy inputs. \emph {Row~2} \textbf {Blur} ($q_3$ axis), \emph {Row~3} \textbf {Colour} ($q_4$ hue axis), \emph {Row~4} \textbf {Combined}: blur + hue + contrast applied jointly. \emph {Takeaway:} the programmatic degradations used to build ITB-LQ preserve lesion identity while sweeping the 5-head IQA scores into the low-quality stratum where Std~VIB calibration collapses and QCTS recovers it (Tables~\ref {tab:main}--\ref {tab:universality})}{figure.caption.6}{}}
