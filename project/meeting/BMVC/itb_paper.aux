\@writefile{lot}{\contentsline {table}{\numberline {1}{\ignorespaces \textbf  {Main results on the ITB benchmark.} AUC and ECE ($M{=}15$ bins) on ITB-LQ ($n{=}300$) and ITB-HQ ($n{=}360$); $\text  {QCDI}=\mathrm  {ECE}_\mathrm  {LQ}-\mathrm  {ECE}_\mathrm  {HQ}$ (closer to $0$ is better); $\rho (H,\bar  q)$ is Spearman correlation on the full ITB pool ($n{=}2{,}820$, more negative is better). Subscripts are half-widths of $1{,}000$-iter bootstrap $95\%$ CIs. \textbf  {Bold}/\underline  {underline}: best/second per column. The \textbf  {Std VIB + QCTS} row (highlighted) is our contribution; VIB-family models trade AUC for tighter calibration, so the headline metrics are ECE and QCDI.}}{9}{table.caption.3}\protected@file@percent }
\newlabel{tab:main}{{1}{9}{\textbf {Main results on the ITB benchmark.} AUC and ECE ($M{=}15$ bins) on ITB-LQ ($n{=}300$) and ITB-HQ ($n{=}360$); $\text {QCDI}=\mathrm {ECE}_\mathrm {LQ}-\mathrm {ECE}_\mathrm {HQ}$ (closer to $0$ is better); $\rho (H,\bar q)$ is Spearman correlation on the full ITB pool ($n{=}2{,}820$, more negative is better). Subscripts are half-widths of $1{,}000$-iter bootstrap $95\%$ CIs. \textbf {Bold}/\underline {underline}: best/second per column. The \textbf {Std VIB + QCTS} row (highlighted) is our contribution; VIB-family models trade AUC for tighter calibration, so the headline metrics are ECE and QCDI}{table.caption.3}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces \textbf  {Quality-conditioned calibration problem.} \textbf  {(a)} Taxonomy: each baseline (and QCTS) placed by HQ ECE ($x$) vs.\ LQ ECE ($y$); the dashed diagonal is QCDI~$=0$ and the three shaded bands mark the regimes of \S  \ref {sec:taxonomy}. \textbf  {(b,c)} Reliability diagrams for four representative methods plus QCTS, conditioned on ITB-LQ and ITB-HQ; a bottom density strip indicates where each method's predictions concentrate. \emph  {Takeaway:} no method outside QCTS leaves the Quality-Oblivious or Quality-Fragile band on ITB-LQ, and high-AUC baselines are the most off-diagonal.}}{9}{figure.caption.4}\protected@file@percent }
\newlabel{fig:problem}{{3}{9}{\textbf {Quality-conditioned calibration problem.} \textbf {(a)} Taxonomy: each baseline (and QCTS) placed by HQ ECE ($x$) vs.\ LQ ECE ($y$); the dashed diagonal is QCDI~$=0$ and the three shaded bands mark the regimes of \S \ref {sec:taxonomy}. \textbf {(b,c)} Reliability diagrams for four representative methods plus QCTS, conditioned on ITB-LQ and ITB-HQ; a bottom density strip indicates where each method's predictions concentrate. \emph {Takeaway:} no method outside QCTS leaves the Quality-Oblivious or Quality-Fragile band on ITB-LQ, and high-AUC baselines are the most off-diagonal}{figure.caption.4}{}}
\citation{brisque}
\citation{clipiqa}
\citation{platt1999probabilistic}
\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces \textbf  {QCTS solution and per-bin effect.} \textbf  {(a)} Learned $T(\bar  q)$ across three seeds (dashed) with the median (solid) and 16/84\% band; the dotted reference is standard TS ($\alpha {=}0$). All seeds discover $\alpha > 0$ (inset). \textbf  {(b)} Per-degradation ECE on ITB-LQ samples in the bottom 20th percentile of each quality dimension; dashed reference is the Std-VIB full-ITB-LQ baseline. \textbf  {(c)} ECE before vs.\ after QCTS by quality bin; QCTS reduces ECE by 12--51\% across the quality spectrum. \emph  {Takeaway:} the temperature lift is concentrated on the bottom quality bins, where calibration collapse is sharpest, and is approximately flat on the HQ tail.}}{10}{figure.caption.5}\protected@file@percent }
\newlabel{fig:qcts}{{4}{10}{\textbf {QCTS solution and per-bin effect.} \textbf {(a)} Learned $T(\bar q)$ across three seeds (dashed) with the median (solid) and 16/84\% band; the dotted reference is standard TS ($\alpha {=}0$). All seeds discover $\alpha > 0$ (inset). \textbf {(b)} Per-degradation ECE on ITB-LQ samples in the bottom 20th percentile of each quality dimension; dashed reference is the Std-VIB full-ITB-LQ baseline. \textbf {(c)} ECE before vs.\ after QCTS by quality bin; QCTS reduces ECE by 12--51\% across the quality spectrum. \emph {Takeaway:} the temperature lift is concentrated on the bottom quality bins, where calibration collapse is sharpest, and is approximately flat on the HQ tail}{figure.caption.5}{}}
\@writefile{lot}{\contentsline {table}{\numberline {2}{\ignorespaces \textbf  {Ablation on the form of $T(\bar  q)$.} Candidate functions fitted on a frozen Std VIB with identical L-BFGS optimisation and validation split (single-seed point estimates). Piecewise-constant minimises validation NLL but collapses QCDI and $\rho $, showing smooth interpolation is essential for quality-aware calibration; dimension-wise and MLP variants add parameters without measurable gain.}}{10}{table.caption.6}\protected@file@percent }
\newlabel{tab:ablation}{{2}{10}{\textbf {Ablation on the form of $T(\bar q)$.} Candidate functions fitted on a frozen Std VIB with identical L-BFGS optimisation and validation split (single-seed point estimates). Piecewise-constant minimises validation NLL but collapses QCDI and $\rho $, showing smooth interpolation is essential for quality-aware calibration; dimension-wise and MLP variants add parameters without measurable gain}{table.caption.6}{}}
