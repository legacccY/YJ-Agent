\@writefile{lot}{\contentsline {table}{\numberline {4}{\ignorespaces \textbf  {Universality of TS reversal and QCTS across five backbone families.} Each backbone evaluated raw / $+$TS / $+$QCTS on the ITB pool ($\rho $: Spearman entropy--$\bar  q$ correlation, more negative is better; QCDI $=$ ECE-LQ $-$ ECE-HQ, closer to $0$ is better). TS reversal manifests as a $\rho $ sign-flip on Std VIB and a QCDI sign-flip on ViT-Tiny and Swin-Tiny; it is near-neutral on the strongly quality-aware ResNet-50 and ConvNeXt-Tiny. QCTS preserves or strengthens $\rho $ and restores QCDI toward zero on all five.}}{12}{table.caption.6}\protected@file@percent }
\newlabel{tab:universality}{{4}{12}{\textbf {Universality of TS reversal and QCTS across five backbone families.} Each backbone evaluated raw / $+$TS / $+$QCTS on the ITB pool ($\rho $: Spearman entropy--$\bar q$ correlation, more negative is better; QCDI $=$ ECE-LQ $-$ ECE-HQ, closer to $0$ is better). TS reversal manifests as a $\rho $ sign-flip on Std VIB and a QCDI sign-flip on ViT-Tiny and Swin-Tiny; it is near-neutral on the strongly quality-aware ResNet-50 and ConvNeXt-Tiny. QCTS preserves or strengthens $\rho $ and restores QCDI toward zero on all five}{table.caption.6}{}}
