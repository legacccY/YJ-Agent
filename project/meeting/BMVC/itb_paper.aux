\@writefile{lot}{\contentsline {table}{\numberline {5}{\ignorespaces \textbf  {Per-corruption entropy--quality correlation on ImageNet-C} (18 corruptions, severity 1--5 averaged; ITB-LQ probe pool $n{=}300$). TS columns omitted: TS leaves $\rho $ unchanged in every cell ($|\Delta \rho |<10^{-4}$). QCTS strengthens negative $\rho $ on \emph  {all 18 corruptions for both backbones} (Wilcoxon signed-rank $p<10^{-4}$). ViT-Tiny gains are $5{-}13\times $ larger than ResNet-50 on average, matching its larger fitted $\alpha {=}1.40$ vs.\ $0.24$. Best per backbone in \textbf  {bold}.}}{13}{table.caption.7}\protected@file@percent }
\newlabel{tab:imagenetc}{{5}{13}{\textbf {Per-corruption entropy--quality correlation on ImageNet-C} (18 corruptions, severity 1--5 averaged; ITB-LQ probe pool $n{=}300$). TS columns omitted: TS leaves $\rho $ unchanged in every cell ($|\Delta \rho |<10^{-4}$). QCTS strengthens negative $\rho $ on \emph {all 18 corruptions for both backbones} (Wilcoxon signed-rank $p<10^{-4}$). ViT-Tiny gains are $5{-}13\times $ larger than ResNet-50 on average, matching its larger fitted $\alpha {=}1.40$ vs.\ $0.24$. Best per backbone in \textbf {bold}}{table.caption.7}{}}
\citation{sensoy2018evidential}
\@writefile{lot}{\contentsline {table}{\numberline {6}{\ignorespaces \textbf  {Zero-shot generalisation and Fitzpatrick fairness.} \textbf  {Panel (a)} TS \emph  {inverts} $\rho $ on both unseen dermoscopy datasets (HAM10000 sign-flip $-0.033\!\to \!+0.324$; PAD-UFES $-0.075\!\to \!+0.072$), reproducing the ITB reversal phenomenon (\S  \ref {sec:main_results}); QCTS preserves the negative correlation on both pools. \textbf  {Panel (b)} On Fitzpatrick V--VI darker-skin samples ($n{=}93{+}43{=}136$), QCTS more than triples the entropy--$\bar  q$ Spearman correlation ($V$: $-0.18\!\to \!-0.30$, $VI$: $+0.02\!\to \!-0.35$) and shifts $V$ from quality-fragile to quality-aware (QCDI $-0.054\!\to \!+0.010$, both within noise of zero), without harming the $I$--$II$ QCDI bands (changes ${<}0.02$).}}{14}{table.caption.8}\protected@file@percent }
\newlabel{tab:generalisation}{{6}{14}{\textbf {Zero-shot generalisation and Fitzpatrick fairness.} \textbf {Panel (a)} TS \emph {inverts} $\rho $ on both unseen dermoscopy datasets (HAM10000 sign-flip $-0.033\!\to \!+0.324$; PAD-UFES $-0.075\!\to \!+0.072$), reproducing the ITB reversal phenomenon (\S \ref {sec:main_results}); QCTS preserves the negative correlation on both pools. \textbf {Panel (b)} On Fitzpatrick V--VI darker-skin samples ($n{=}93{+}43{=}136$), QCTS more than triples the entropy--$\bar q$ Spearman correlation ($V$: $-0.18\!\to \!-0.30$, $VI$: $+0.02\!\to \!-0.35$) and shifts $V$ from quality-fragile to quality-aware (QCDI $-0.054\!\to \!+0.010$, both within noise of zero), without harming the $I$--$II$ QCDI bands (changes ${<}0.02$)}{table.caption.8}{}}
