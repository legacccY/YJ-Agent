\@writefile{lot}{\contentsline {table}{\numberline {1}{\ignorespaces \textbf  {Main results on the ITB benchmark.} AUC and ECE ($M{=}15$ bins) on ITB-LQ ($n{=}300$) and ITB-HQ ($n{=}360$); $\text  {QCDI}=\mathrm  {ECE}_\mathrm  {LQ}-\mathrm  {ECE}_\mathrm  {HQ}$ (closer to $0$ is better); $\rho (H,\bar  q)$ is Spearman correlation on the full ITB pool ($n{=}2{,}820$, more negative is better). Values shown as $\text  {point}\,{\scriptscriptstyle \pm }\,\text  {half-width of $1{,}000$-iter bootstrap $95\%$ CI}$. \textbf  {Bold}/\underline  {underline}: directionally best/second per column (lower for ECE/QCDI, higher for AUC, more negative for $\rho $). The \textbf  {Std VIB + QCTS} row (highlighted) is our contribution; VIB-family models trade AUC for tighter calibration, so the headline metrics are ECE and QCDI. \emph  {Statistical rigor.} Five pairwise QCTS-vs-baseline ECE comparisons survive Bonferroni correction (smallest corrected $p{=}0.0015$); Cohen's $d{=}0.452$ on ITB-LQ ECE; at the $0.03$ ECE minimum clinically meaningful difference, $n{=}300$ gives power $0.929$ (supp \S  A16). All $\rho $ values bootstrap-significant at $p{<}10^{-20}$ via $10^4$ resamples.}}{6}{table.caption.2}\protected@file@percent }
\newlabel{tab:main}{{1}{6}{\textbf {Main results on the ITB benchmark.} AUC and ECE ($M{=}15$ bins) on ITB-LQ ($n{=}300$) and ITB-HQ ($n{=}360$); $\text {QCDI}=\mathrm {ECE}_\mathrm {LQ}-\mathrm {ECE}_\mathrm {HQ}$ (closer to $0$ is better); $\rho (H,\bar q)$ is Spearman correlation on the full ITB pool ($n{=}2{,}820$, more negative is better). Values shown as $\text {point}\,{\scriptscriptstyle \pm }\,\text {half-width of $1{,}000$-iter bootstrap $95\%$ CI}$. \textbf {Bold}/\underline {underline}: directionally best/second per column (lower for ECE/QCDI, higher for AUC, more negative for $\rho $). The \textbf {Std VIB + QCTS} row (highlighted) is our contribution; VIB-family models trade AUC for tighter calibration, so the headline metrics are ECE and QCDI. \emph {Statistical rigor.} Five pairwise QCTS-vs-baseline ECE comparisons survive Bonferroni correction (smallest corrected $p{=}0.0015$); Cohen's $d{=}0.452$ on ITB-LQ ECE; at the $0.03$ ECE minimum clinically meaningful difference, $n{=}300$ gives power $0.929$ (supp \S A16). All $\rho $ values bootstrap-significant at $p{<}10^{-20}$ via $10^4$ resamples}{table.caption.2}{}}
\newlabel{eq:pipeline}{{5}{6}{Main Results and Calibration Taxonomy}{equation.5}{}}
