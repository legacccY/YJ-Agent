\@writefile{toc}{\contentsline {subsection}{\numberline {5.3}QCTS Analysis}{8}{subsection.5.3}\protected@file@percent }
\newlabel{sec:qcts_analysis}{{5.3}{8}{QCTS Analysis}{subsection.5.3}{}}
\@writefile{lot}{\contentsline {table}{\numberline {1}{\ignorespaces  \textbf  {Main results on the ITB benchmark.} AUC and Expected Calibration Error (ECE, $M{=}15$ bins) on ITB-LQ ($n{=}300$) and ITB-HQ ($n{=}360$). \textbf  {QCDI} $= \mathrm  {ECE}_\mathrm  {LQ} - \mathrm  {ECE}_\mathrm  {HQ}$ (closer to 0 = more quality-aware). $\rho (\!H,\bar  q\!)$: Spearman correlation between predictive entropy and quality on the full ITB pool ($n{=}2{,}820$); more negative = more quality-aware. Subscripts: half-width of 1{,}000-iter bootstrap 95\% CI. \textbf  {Bold}/\underline  {underline} = best/second best per column. Cell shade is a per-column heat-map (red = worse, green = better, scaled to that column's range); the \textbf  {Std VIB + QCTS} row is highlighted as our contribution. Note that VIB-family models intentionally trade discriminative AUC for tighter calibration; the headline metrics are ECE and QCDI. }}{9}{table.caption.3}\protected@file@percent }
\newlabel{tab:main}{{1}{9}{\textbf {Main results on the ITB benchmark.} AUC and Expected Calibration Error (ECE, $M{=}15$ bins) on ITB-LQ ($n{=}300$) and ITB-HQ ($n{=}360$). \textbf {QCDI} $= \mathrm {ECE}_\mathrm {LQ} - \mathrm {ECE}_\mathrm {HQ}$ (closer to 0 = more quality-aware). $\rho (\!H,\bar q\!)$: Spearman correlation between predictive entropy and quality on the full ITB pool ($n{=}2{,}820$); more negative = more quality-aware. Subscripts: half-width of 1{,}000-iter bootstrap 95\% CI. \textbf {Bold}/\underline {underline} = best/second best per column. Cell shade is a per-column heat-map (red = worse, green = better, scaled to that column's range); the \textbf {Std VIB + QCTS} row is highlighted as our contribution. Note that VIB-family models intentionally trade discriminative AUC for tighter calibration; the headline metrics are ECE and QCDI}{table.caption.3}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces \textbf  {Quality-conditioned calibration problem.} \textbf  {(a)} Taxonomy: each baseline (and QCTS) placed by HQ ECE ($x$) vs.\ LQ ECE ($y$); the dashed diagonal is QCDI~$=0$ and the three shaded bands mark the regimes of \S  \ref {sec:taxonomy}. \textbf  {(b,c)} Reliability diagrams for four representative methods plus QCTS, conditioned on ITB-LQ and ITB-HQ; a bottom density strip indicates where each method's predictions concentrate. \emph  {Takeaway:} no method outside QCTS leaves the Quality-Oblivious or Quality-Fragile band on ITB-LQ, and high-AUC baselines are the most off-diagonal.}}{9}{figure.caption.4}\protected@file@percent }
\newlabel{fig:problem}{{3}{9}{\textbf {Quality-conditioned calibration problem.} \textbf {(a)} Taxonomy: each baseline (and QCTS) placed by HQ ECE ($x$) vs.\ LQ ECE ($y$); the dashed diagonal is QCDI~$=0$ and the three shaded bands mark the regimes of \S \ref {sec:taxonomy}. \textbf {(b,c)} Reliability diagrams for four representative methods plus QCTS, conditioned on ITB-LQ and ITB-HQ; a bottom density strip indicates where each method's predictions concentrate. \emph {Takeaway:} no method outside QCTS leaves the Quality-Oblivious or Quality-Fragile band on ITB-LQ, and high-AUC baselines are the most off-diagonal}{figure.caption.4}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces \textbf  {QCTS solution and per-bin effect.} \textbf  {(a)} Learned $T(\bar  q)$ across three seeds (dashed) with the median (solid) and 16/84\% band; the dotted reference is standard TS ($\alpha {=}0$). All seeds discover $\alpha > 0$ (inset). \textbf  {(b)} Per-degradation ECE on ITB-LQ samples in the bottom 20th percentile of each quality dimension; dashed reference is the Std-VIB full-ITB-LQ baseline. \textbf  {(c)} ECE before vs.\ after QCTS by quality bin; QCTS reduces ECE by 12--51\% across the quality spectrum. \emph  {Takeaway:} the temperature lift is concentrated on the bottom quality bins, where calibration collapse is sharpest, and is approximately flat on the HQ tail.}}{10}{figure.caption.5}\protected@file@percent }
\newlabel{fig:qcts}{{4}{10}{\textbf {QCTS solution and per-bin effect.} \textbf {(a)} Learned $T(\bar q)$ across three seeds (dashed) with the median (solid) and 16/84\% band; the dotted reference is standard TS ($\alpha {=}0$). All seeds discover $\alpha > 0$ (inset). \textbf {(b)} Per-degradation ECE on ITB-LQ samples in the bottom 20th percentile of each quality dimension; dashed reference is the Std-VIB full-ITB-LQ baseline. \textbf {(c)} ECE before vs.\ after QCTS by quality bin; QCTS reduces ECE by 12--51\% across the quality spectrum. \emph {Takeaway:} the temperature lift is concentrated on the bottom quality bins, where calibration collapse is sharpest, and is approximately flat on the HQ tail}{figure.caption.5}{}}
\@writefile{lot}{\contentsline {table}{\numberline {2}{\ignorespaces  \textbf  {Ablation on the form of $T(\bar  q)$.} Three candidate functions for the quality-conditioned temperature, fitted on a frozen Std VIB backbone with identical L-BFGS optimisation and validation split. Numbers are single-seed point estimates on the validation set, chosen for a controlled across-form comparison; the bootstrap-CI'd 3-seed result for the softplus form is the QCTS row of Table~\ref {tab:main}. Piecewise-constant minimises validation NLL but produces the worst QCDI and a near-zero $\rho $, so minimising NLL alone is not sufficient: a smooth interpolation across $\bar  q$ is what turns post-hoc calibration into quality-aware calibration. }}{10}{table.caption.6}\protected@file@percent }
\newlabel{tab:ablation}{{2}{10}{\textbf {Ablation on the form of $T(\bar q)$.} Three candidate functions for the quality-conditioned temperature, fitted on a frozen Std VIB backbone with identical L-BFGS optimisation and validation split. Numbers are single-seed point estimates on the validation set, chosen for a controlled across-form comparison; the bootstrap-CI'd 3-seed result for the softplus form is the QCTS row of Table~\ref {tab:main}. Piecewise-constant minimises validation NLL but produces the worst QCDI and a near-zero $\rho $, so minimising NLL alone is not sufficient: a smooth interpolation across $\bar q$ is what turns post-hoc calibration into quality-aware calibration}{table.caption.6}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {5.4}Universality across Backbone Families}{10}{subsection.5.4}\protected@file@percent }
\newlabel{sec:universality}{{5.4}{10}{Universality across Backbone Families}{subsection.5.4}{}}
\@writefile{lot}{\contentsline {table}{\numberline {3}{\ignorespaces  \textbf  {Universality of TS reversal and QCTS across backbone families.} Three backbones spanning VIB, CNN and Transformer families, each evaluated raw / + standard TS / + QCTS on the ITB pool. $\rho $: Spearman correlation between predictive entropy and $\bar  q$ on ITB-LQ$\cup $Edge$\cup $HQ; more negative = more quality-aware. QCDI $=$ ECE-LQ $-$ ECE-HQ; closer to 0 = more quality-invariant. TS reversal manifests in two empirical signatures: \textbf  {$\rho $ sign-flip} on Std VIB ($-0.153 \to +0.241$) and \textbf  {QCDI sign-flip} on ViT-Tiny ($+0.023 \to -0.029$); on the more strongly quality-aware ResNet-50 (raw $\rho =-0.368$) standard TS is approximately neutral. QCTS preserves or strengthens $\rho $ and keeps QCDI close to zero on all three. }}{11}{table.caption.7}\protected@file@percent }
\newlabel{tab:universality}{{3}{11}{\textbf {Universality of TS reversal and QCTS across backbone families.} Three backbones spanning VIB, CNN and Transformer families, each evaluated raw / + standard TS / + QCTS on the ITB pool. $\rho $: Spearman correlation between predictive entropy and $\bar q$ on ITB-LQ$\cup $Edge$\cup $HQ; more negative = more quality-aware. QCDI $=$ ECE-LQ $-$ ECE-HQ; closer to 0 = more quality-invariant. TS reversal manifests in two empirical signatures: \textbf {$\rho $ sign-flip} on Std VIB ($-0.153 \to +0.241$) and \textbf {QCDI sign-flip} on ViT-Tiny ($+0.023 \to -0.029$); on the more strongly quality-aware ResNet-50 (raw $\rho =-0.368$) standard TS is approximately neutral. QCTS preserves or strengthens $\rho $ and keeps QCDI close to zero on all three}{table.caption.7}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {5}{\ignorespaces \textbf  {Empirical validation of softplus $T(\bar  q)$ (a) and TS reversal asymmetry (b)} on the two probe backbones. See \S  \ref {sec:universality}. \emph  {Takeaway:} a single backbone-dependent $\alpha $ recovers the empirical per-bin optimum $T^*(\bar  q)$, and removes the QCDI sign-flip on the backbone where standard TS introduces one.}}{11}{figure.caption.8}\protected@file@percent }
\newlabel{fig:universality_figs}{{5}{11}{\textbf {Empirical validation of softplus $T(\bar q)$ (a) and TS reversal asymmetry (b)} on the two probe backbones. See \S \ref {sec:universality}. \emph {Takeaway:} a single backbone-dependent $\alpha $ recovers the empirical per-bin optimum $T^*(\bar q)$, and removes the QCDI sign-flip on the backbone where standard TS introduces one}{figure.caption.8}{}}
\citation{sensoy2018evidential}
\@writefile{lof}{\contentsline {figure}{\numberline {6}{\ignorespaces \textbf  {QCTS generalises across datasets, backbones, and skin tones.} \textbf  {(a)} Entropy vs.\ $\bar  q$ on HAM10000 zero-shot; the per-bin median trend (coloured line) becomes more negative from Std VIB to Std VIB + QCTS, confirming that the quality-aware behaviour learned on ISIC transfers to a natural-distribution dataset. \textbf  {(b)} QCDI on three datasets across the evaluated baselines, with Kendall~$\tau $ summarising ranking consistency. \textbf  {(c)} Per-skin-type QCDI on ITB-Diverse for Std VIB and Std VIB + QCTS; QCTS keeps the V--VI QCDI in the 0.01--0.02 range without introducing new bias on lighter skin types. \emph  {Takeaway:} the QCDI ranking from ITB transfers to two unseen dermoscopy datasets and narrows the Fitzpatrick V--VI calibration gap without harming lighter skin tones.}}{12}{figure.caption.9}\protected@file@percent }
\newlabel{fig:generalization}{{6}{12}{\textbf {QCTS generalises across datasets, backbones, and skin tones.} \textbf {(a)} Entropy vs.\ $\bar q$ on HAM10000 zero-shot; the per-bin median trend (coloured line) becomes more negative from Std VIB to Std VIB + QCTS, confirming that the quality-aware behaviour learned on ISIC transfers to a natural-distribution dataset. \textbf {(b)} QCDI on three datasets across the evaluated baselines, with Kendall~$\tau $ summarising ranking consistency. \textbf {(c)} Per-skin-type QCDI on ITB-Diverse for Std VIB and Std VIB + QCTS; QCTS keeps the V--VI QCDI in the 0.01--0.02 range without introducing new bias on lighter skin types. \emph {Takeaway:} the QCDI ranking from ITB transfers to two unseen dermoscopy datasets and narrows the Fitzpatrick V--VI calibration gap without harming lighter skin tones}{figure.caption.9}{}}
