\newlabel{sec:imagenetc}{{5.5}{11}{ImageNet-C: Quality-Scalar Universality}{subsection.5.5}{}}
\@writefile{lot}{\contentsline {table}{\numberline {3}{\ignorespaces \textbf  {Universality of TS reversal and QCTS across five backbone families.} Each backbone evaluated raw / $+$TS / $+$QCTS on the ITB pool ($\rho $: Spearman entropy--$\bar  q$ correlation, more negative is better; QCDI $=$ ECE-LQ $-$ ECE-HQ, closer to $0$ is better). TS reversal manifests as a $\rho $ sign-flip on Std VIB and a QCDI sign-flip on ViT-Tiny and Swin-Tiny; it is near-neutral on the strongly quality-aware ResNet-50 and ConvNeXt-Tiny. QCTS preserves or strengthens $\rho $ and restores QCDI toward zero on all five.}}{12}{table.caption.7}\protected@file@percent }
\newlabel{tab:universality}{{3}{12}{\textbf {Universality of TS reversal and QCTS across five backbone families.} Each backbone evaluated raw / $+$TS / $+$QCTS on the ITB pool ($\rho $: Spearman entropy--$\bar q$ correlation, more negative is better; QCDI $=$ ECE-LQ $-$ ECE-HQ, closer to $0$ is better). TS reversal manifests as a $\rho $ sign-flip on Std VIB and a QCDI sign-flip on ViT-Tiny and Swin-Tiny; it is near-neutral on the strongly quality-aware ResNet-50 and ConvNeXt-Tiny. QCTS preserves or strengthens $\rho $ and restores QCDI toward zero on all five}{table.caption.7}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {5}{\ignorespaces \textbf  {Empirical validation of softplus $T(\bar  q)$ (a) and TS reversal asymmetry (b)} on the two probe backbones. See \S  \ref {sec:universality}. \emph  {Takeaway:} a single backbone-dependent $\alpha $ recovers the empirical per-bin optimum $T^*(\bar  q)$, and removes the QCDI sign-flip on the backbone where standard TS introduces one.}}{12}{figure.caption.8}\protected@file@percent }
\newlabel{fig:universality_figs}{{5}{12}{\textbf {Empirical validation of softplus $T(\bar q)$ (a) and TS reversal asymmetry (b)} on the two probe backbones. See \S \ref {sec:universality}. \emph {Takeaway:} a single backbone-dependent $\alpha $ recovers the empirical per-bin optimum $T^*(\bar q)$, and removes the QCDI sign-flip on the backbone where standard TS introduces one}{figure.caption.8}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {6}{\ignorespaces \textbf  {QCTS improves quality-awareness across 18 ImageNet-C corruptions.} Each point is one corruption type (averaged across five severity levels); $x$-axis is raw $\rho (H,\bar  q)$, $y$-axis is QCTS $\rho $. All points fall below the diagonal ($y{=}x$), confirming QCTS universally strengthens the entropy--quality correlation when corruption severity serves as $\bar  q$. \emph  {Takeaway:} QCTS generalises to a non-learned, domain-agnostic quality scalar; TS is neutral on ImageNet-C, indicating TS reversal is backbone-specific rather than universal.}}{13}{figure.caption.9}\protected@file@percent }
\newlabel{fig:imagenetc}{{6}{13}{\textbf {QCTS improves quality-awareness across 18 ImageNet-C corruptions.} Each point is one corruption type (averaged across five severity levels); $x$-axis is raw $\rho (H,\bar q)$, $y$-axis is QCTS $\rho $. All points fall below the diagonal ($y{=}x$), confirming QCTS universally strengthens the entropy--quality correlation when corruption severity serves as $\bar q$. \emph {Takeaway:} QCTS generalises to a non-learned, domain-agnostic quality scalar; TS is neutral on ImageNet-C, indicating TS reversal is backbone-specific rather than universal}{figure.caption.9}{}}
