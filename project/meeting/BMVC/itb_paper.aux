\@writefile{lot}{\contentsline {table}{\numberline {2}{\ignorespaces \textbf  {Ablation on the form of $T(\bar  q)$.} Candidate functions fitted on a frozen Std VIB with identical L-BFGS optimisation and validation split (single-seed point estimates). Piecewise-constant minimises validation NLL but collapses QCDI and $\rho $, showing smooth interpolation is essential for quality-aware calibration; dimension-wise and MLP variants add parameters without measurable gain.}}{7}{table.caption.3}\protected@file@percent }
\newlabel{tab:ablation}{{2}{7}{\textbf {Ablation on the form of $T(\bar q)$.} Candidate functions fitted on a frozen Std VIB with identical L-BFGS optimisation and validation split (single-seed point estimates). Piecewise-constant minimises validation NLL but collapses QCDI and $\rho $, showing smooth interpolation is essential for quality-aware calibration; dimension-wise and MLP variants add parameters without measurable gain}{table.caption.3}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {5.4}Universality across Backbone Families}{7}{subsection.5.4}\protected@file@percent }
\newlabel{sec:universality}{{5.4}{7}{Universality across Backbone Families}{subsection.5.4}{}}
\@writefile{lot}{\contentsline {table}{\numberline {3}{\ignorespaces \textbf  {Universality of TS reversal and QCTS across three backbone families.} Each backbone evaluated raw / $+$TS / $+$QCTS on the ITB pool ($\rho $: Spearman entropy--$\bar  q$ correlation, more negative is better; QCDI $=$ ECE-LQ $-$ ECE-HQ, closer to $0$ is better). TS reversal manifests as a $\rho $ sign-flip on Std~VIB and a QCDI sign-flip on ViT-Tiny; it is near-neutral on the strongly quality-aware ResNet-50. ConvNeXt-Tiny and Swin-Tiny in supp \S  A12. QCTS preserves or strengthens $\rho $ and restores QCDI toward zero on all five.}}{8}{table.caption.4}\protected@file@percent }
\newlabel{tab:universality}{{3}{8}{\textbf {Universality of TS reversal and QCTS across three backbone families.} Each backbone evaluated raw / $+$TS / $+$QCTS on the ITB pool ($\rho $: Spearman entropy--$\bar q$ correlation, more negative is better; QCDI $=$ ECE-LQ $-$ ECE-HQ, closer to $0$ is better). TS reversal manifests as a $\rho $ sign-flip on Std~VIB and a QCDI sign-flip on ViT-Tiny; it is near-neutral on the strongly quality-aware ResNet-50. ConvNeXt-Tiny and Swin-Tiny in supp \S A12. QCTS preserves or strengthens $\rho $ and restores QCDI toward zero on all five}{table.caption.4}{}}
