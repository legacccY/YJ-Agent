\@writefile{lof}{\contentsline {figure}{\numberline {1}{\ignorespaces R1 Hippocampus training. \textbf  {Left:} per-epoch training loss. \textbf  {Right:} eval mean Dice (every 25 epochs, $\pm $std) for the zero-deviation official implementation, approaching both the fast-implementation anchor ($0.866$) and the paper target ($0.886$).}}{3}{figure.caption.11}\protected@file@percent }
\newlabel{fig:conv}{{1}{3}{R1 Hippocampus training. \textbf {Left:} per-epoch training loss. \textbf {Right:} eval mean Dice (every 25 epochs, $\pm $std) for the zero-deviation official implementation, approaching both the fast-implementation anchor ($0.866$) and the paper target ($0.886$)}{figure.caption.11}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces Inference-step sweep (C1) on the official checkpoint (trained at 16 steps). Dice peaks exactly at the training step count (steps$=16$, $\mathrm  {Dice}=0.865$) and degrades on either side; over-stepping ($\geq 48$ steps) collapses the output ($\mathrm  {Dice}<0.24$) as the cell state over-evolves. This contrasts sharply with the deprecated fast run (trained at 64 steps, monotonic saturation toward 64) and shows that NCA inference must match the training step count --- Med-NCA is not over-step-stable.}}{3}{figure.caption.12}\protected@file@percent }
\newlabel{fig:c1}{{2}{3}{Inference-step sweep (C1) on the official checkpoint (trained at 16 steps). Dice peaks exactly at the training step count (steps$=16$, $\dice =0.865$) and degrades on either side; over-stepping ($\geq 48$ steps) collapses the output ($\dice <0.24$) as the cell state over-evolves. This contrasts sharply with the deprecated fast run (trained at 64 steps, monotonic saturation toward 64) and shows that NCA inference must match the training step count --- Med-NCA is not over-step-stable}{figure.caption.12}{}}
