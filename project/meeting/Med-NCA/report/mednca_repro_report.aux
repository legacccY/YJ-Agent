\@writefile{toc}{\contentsline {subsection}{\numberline {5.3}The 9-seed sweep: $0/9$ survive}{4}{subsection.5.3}\protected@file@percent }
\@writefile{toc}{\contentsline {subsection}{\numberline {5.4}Root cause: an unstable config plus uncontrolled floating-point nondeterminism}{4}{subsection.5.4}\protected@file@percent }
\newlabel{sec:r2root}{{5.4}{4}{Root cause: an unstable config plus uncontrolled floating-point nondeterminism}{subsection.5.4}{}}
\@writefile{toc}{\contentsline {paragraph}{(i) The config is dynamically unstable.}{4}{section*.19}\protected@file@percent }
\citation{pytorch_repro}
\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces \textbf  {The Prostate instability (zero-deviation, 9-seed sweep).} \textbf  {(a)} Epoch-1 training loss is bimodal: $2/9$ seeds land in the good basin ($\approx 1.3$), $7/9$ in the bad basin ($3.3$--$4.5$); the basin is fixed on the very first epoch. \textbf  {(b)} Full loss trajectories: the $7$ bad-basin seeds stay flat-high; the $2$ good-basin seeds (green) train healthily, then collapse off a cliff at epochs 61 and 122. \textbf  {(c)} Crash-epoch timeline over all 11 official-config attempts (9 fresh seeds + 2 history 1000-ep runs + 1 manually-stopped 301-ep run): $0/11$ reach the paper's 1000 epochs.}}{5}{figure.caption.17}\protected@file@percent }
\newlabel{fig:seed}{{4}{5}{\textbf {The Prostate instability (zero-deviation, 9-seed sweep).} \textbf {(a)} Epoch-1 training loss is bimodal: $2/9$ seeds land in the good basin ($\approx 1.3$), $7/9$ in the bad basin ($3.3$--$4.5$); the basin is fixed on the very first epoch. \textbf {(b)} Full loss trajectories: the $7$ bad-basin seeds stay flat-high; the $2$ good-basin seeds (green) train healthily, then collapse off a cliff at epochs 61 and 122. \textbf {(c)} Crash-epoch timeline over all 11 official-config attempts (9 fresh seeds + 2 history 1000-ep runs + 1 manually-stopped 301-ep run): $0/11$ reach the paper's 1000 epochs}{figure.caption.17}{}}
\@writefile{toc}{\contentsline {paragraph}{(ii) Fixed seeds do not make it reproducible.}{5}{section*.20}\protected@file@percent }
\@writefile{toc}{\contentsline {paragraph}{Why one run ``succeeded'' --- survivorship.}{5}{section*.21}\protected@file@percent }
\@writefile{toc}{\contentsline {paragraph}{Verdict.}{5}{section*.22}\protected@file@percent }
\@writefile{toc}{\contentsline {section}{\numberline {6}Reproducibility Fragility: Three Levels of Nondeterminism}{5}{section.6}\protected@file@percent }
\newlabel{sec:rng}{{6}{5}{Reproducibility Fragility: Three Levels of Nondeterminism}{section.6}{}}
\@writefile{toc}{\contentsline {paragraph}{(1) A ``free'' RNG-stream change breaks it (controlled pair).}{5}{section*.23}\protected@file@percent }
\citation{pytorch_repro}
\@writefile{lof}{\contentsline {figure}{\numberline {5}{\ignorespaces \textbf  {Two levels of nondeterminism, both on Prostate.} \textbf  {(a)} A mathematically equivalent CPU$\rightarrow $GPU change to the fire-mask RNG \emph  {stream} collapses training from $0.672$ to $0.0$. \textbf  {(b)} With the official seed-controlled fire mask held fixed, the \emph  {same} seed 42 still gives epoch-1 loss $1.25$ (converged) vs.\ $4.33$ (diverged) across two runs --- the deciding perturbation is cuDNN/atomic floating-point nondeterminism, not the seed.}}{6}{figure.caption.26}\protected@file@percent }
\newlabel{fig:rng}{{5}{6}{\textbf {Two levels of nondeterminism, both on Prostate.} \textbf {(a)} A mathematically equivalent CPU$\rightarrow $GPU change to the fire-mask RNG \emph {stream} collapses training from $0.672$ to $0.0$. \textbf {(b)} With the official seed-controlled fire mask held fixed, the \emph {same} seed 42 still gives epoch-1 loss $1.25$ (converged) vs.\ $4.33$ (diverged) across two runs --- the deciding perturbation is cuDNN/atomic floating-point nondeterminism, not the seed}{figure.caption.26}{}}
\@writefile{toc}{\contentsline {paragraph}{(2) The same config diverges across runs (FP nondeterminism).}{6}{section*.24}\protected@file@percent }
\@writefile{toc}{\contentsline {paragraph}{(3) The same \emph  {seed} diverges (strongest).}{6}{section*.25}\protected@file@percent }
\@writefile{toc}{\contentsline {paragraph}{Takeaway.}{6}{section*.27}\protected@file@percent }
