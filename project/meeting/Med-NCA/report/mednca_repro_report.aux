\@writefile{toc}{\contentsline {section}{\numberline {6}Reproducibility Fragility: an RNG Case Study}{3}{section.6}\protected@file@percent }
\newlabel{sec:rng}{{6}{3}{Reproducibility Fragility: an RNG Case Study}{section.6}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces \textbf  {Reproducibility fragility.} On Prostate (a controlled pair: identical config, RNG source only) a mathematically equivalent CPU$\rightarrow $GPU change to fire-mask sampling collapses training from $0.672$ to $0.0$ (divergence). The Hippocampus bars converge but differ in configuration too (ch16/64-step vs.\ ch32/16-step), so they are shown only as a forgiving-regime reference, not a controlled RNG test.}}{4}{figure.caption.19}\protected@file@percent }
\newlabel{fig:rng}{{4}{4}{\textbf {Reproducibility fragility.} On Prostate (a controlled pair: identical config, RNG source only) a mathematically equivalent CPU$\rightarrow $GPU change to fire-mask sampling collapses training from $0.672$ to $0.0$ (divergence). The Hippocampus bars converge but differ in configuration too (ch16/64-step vs.\ ch32/16-step), so they are shown only as a forgiving-regime reference, not a controlled RNG test}{figure.caption.19}{}}
